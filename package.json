{
  "name": "tanamao",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --prefix frontend",
    "dev:server": "npm run dev --prefix server",
    "build": "npm install --prefix frontend && npm install --prefix server && npm run build --prefix frontend",
    "start": "npm run start --prefix server"
  },
  "engines": {
    "node": "22"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
